{
  "name": "pluginpack-action",
  "description": "GitHub Action that builds a pluginpack source repo and syncs generated plugin output into a published repo via pull request.",
  "version": "0.0.0",
  "author": "Glean",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/gleanwork/pluginpack-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gleanwork/pluginpack-action.git"
  },
  "bugs": {
    "url": "https://github.com/gleanwork/pluginpack-action/issues"
  },
  "keywords": [
    "actions",
    "pluginpack",
    "glean"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "vitest run",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "vitest run",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@github/local-action": "^7.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.57.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
